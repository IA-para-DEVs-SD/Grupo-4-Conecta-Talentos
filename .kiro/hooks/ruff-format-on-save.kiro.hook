{
  "enabled": true,
  "name": "Ruff Format on Save",
  "description": "Formata código Python automaticamente com ruff format quando arquivos são salvos",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "ruff format .",
    "timeout": 30
  }
}